{
  "name": "AI Language Compiler",
  "image": "mcr.microsoft.com/devcontainers/rust:0.1",
  "features": {
    "ghcr.io/devcontainers/features/rust:1": {},
    "ghcr.io/devcontainers-contrib/features/zsh:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "serayuzgur.crates"
      ]
    }
  },
  "postCreateCommand": "cargo build && echo '✅ Build successful! Run with: cargo run'"
}
